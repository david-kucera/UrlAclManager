<Window x:Class="UrlAclManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UrlAclManager"
        mc:Ignorable="d"
        Title="URL ACL Manager" Icon="/app_icon.ico" MinHeight="560" Height="680" MinWidth="680" Width="820" WindowStartupLocation="CenterScreen" Background="#F7F9FC" FontFamily="Segoe UI">
    <Window.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="BgDeep"       Color="#F7F9FC"/>
        <SolidColorBrush x:Key="BgPanel"      Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BgCard"       Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BgInput"      Color="#FFFFFF"/>
        <SolidColorBrush x:Key="AccentBlue"   Color="#2F6FE8"/>
        <SolidColorBrush x:Key="AccentGreen"  Color="#1E9E58"/>
        <SolidColorBrush x:Key="AccentRed"    Color="#D64545"/>
        <SolidColorBrush x:Key="AccentOrange" Color="#E89A2F"/>
        <SolidColorBrush x:Key="TextPrimary"  Color="#1F2937"/>
        <SolidColorBrush x:Key="TextMuted"    Color="#6B7280"/>
        <SolidColorBrush x:Key="Border1"      Color="#D1D5DB"/>

        <!-- Primary Button Style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"   Value="#2F6FE8"/>
            <Setter Property="Foreground"   Value="#FFFFFF"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Padding"      Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#6BA3FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#3A77E8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#2A3050"/>
                                <Setter TargetName="Root" Property="Effect" Value="{x:Null}"/>
                                <Setter Property="Foreground" Value="#4A5070"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger Button Style -->
        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#D64545"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="12,6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#3A2530"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2A1820"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#F75F5F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#3A1E28"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox Style -->
        <Style x:Key="UrlInput" TargetType="TextBox">
            <Setter Property="Background"        Value="#FFFFFF"/>
            <Setter Property="Foreground"        Value="#111827"/>
            <Setter Property="CaretBrush"        Value="#2F6FE8"/>
            <Setter Property="BorderThickness"   Value="1.5"/>
            <Setter Property="BorderBrush"       Value="#D1D5DB"/>
            <Setter Property="FontSize"          Value="14"/>
            <Setter Property="Padding"           Value="14,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#4F8EF7"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#3A4060"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ScrollBar Style -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width"      Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#E5E7EB" CornerRadius="3"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid Background="{StaticResource BgDeep}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Input Section -->
            <RowDefinition Height="*"/>
            <!-- Registered URLs list -->
            <RowDefinition Height="160"/>
            <!-- Console output -->
        </Grid.RowDefinitions>

        <!-- ── HEADER ── -->
        <Border Grid.Row="0" Background="#FFFFFF" Padding="28,18,28,18" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="2" Opacity="0.4"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Icon -->
                    <Border Width="36" Height="36" CornerRadius="8" Background="#1E2845" Margin="0,0,14,0">
                        <Image Source="pack://application:,,,/app_icon.ico" Width="40" Height="40" HorizontalAlignment="Center" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                    <StackPanel>
                        <TextBlock Text="URL ACL Manager"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="#111827"/>
                        <TextBlock Text="netsh http urlacl — register &amp; manage URL reservations"
                                   FontSize="11" Foreground="#6B7280" Margin="0,1,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Admin badge -->
                <Border Grid.Column="1" x:Name="AdminBadge"
                        CornerRadius="6" Padding="10,5" VerticalAlignment="Center"
                        Background="#FEE2E2">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" Fill="#EF4444" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock x:Name="AdminBadgeText"
                                   Text="Administrator"
                                   Foreground="#991B1B" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ── INPUT SECTION ── -->
        <Border Grid.Row="1" Background="#F9FAFB" Padding="24,20" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="REGISTER NEW URL"
                           FontSize="10" FontWeight="Bold"
                           Foreground="#6B7280"/>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- URL Input -->
                    <Grid Grid.Column="0">
                        <TextBox x:Name="UrlTextBox" Style="{StaticResource UrlInput}" Height="44" FontSize="18" TextAlignment="Left" KeyDown="UrlTextBox_KeyDown"/>
                        <TextBlock Text="https://example.com/ or http://+" Margin="18,0,0,0" VerticalAlignment="Center" Foreground="#9CA3AF" IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding Text, ElementName=UrlTextBox}" Value=""/>
                                                <Condition Binding="{Binding IsKeyboardFocused, ElementName=UrlTextBox}" Value="False"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!-- Register button -->
                    <Button Grid.Column="2" x:Name="RegisterButton"
                            Style="{StaticResource PrimaryButton}"
                            Height="44" Padding="22,0"
                            Click="RegisterButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="+" FontSize="18" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Register" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Border>

        <!-- ── REGISTERED URLS LIST ── -->
        <Border Grid.Row="2" Margin="24,0,24,0" Background="#F9FAFB">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="REGISTERED URLS"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="#6B7280" VerticalAlignment="Center"/>
                            <Border x:Name="UrlCountBadge"
                                    Background="#E5E7EB" CornerRadius="10"
                                    Padding="8,2" Margin="10,1,0,0">
                                <TextBlock x:Name="UrlCountText"
                                           Text="0" FontSize="11" FontWeight="Bold"
                                           Foreground="#1D4ED8"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Ellipse Width="8" Height="8" Fill="#16A34A" VerticalAlignment="Center"/>
                            <TextBlock Text="  App registration" FontSize="10" Foreground="#6B7280" Margin="4,0,10,0"/>
                            <Ellipse Width="8" Height="8" Fill="#9CA3AF" VerticalAlignment="Center"/>
                            <TextBlock Text="  System URL ACL" FontSize="10" Foreground="#6B7280" Margin="4,0,10,0"/>
                            <Button x:Name="RefreshButton"
                                    Content="↻  Refresh from system"
                                    Cursor="Hand" Click="RefreshButton_Click"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="#6B7280" FontSize="11" Padding="0"
                                    HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0">
                            <TextBox x:Name="FilterTextBox"
                                     Style="{StaticResource UrlInput}"
                                     Height="34"
                                     FontSize="13"
                                     ToolTip="Search URL ACLs"
                                     TextChanged="FilterTextBox_TextChanged"/>
                            <TextBlock Text="Search URLs or users" Margin="18,0,0,0" VerticalAlignment="Center" Foreground="#9CA3AF" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Text, ElementName=FilterTextBox}" Value=""/>
                                                    <Condition Binding="{Binding IsKeyboardFocused, ElementName=FilterTextBox}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <CheckBox x:Name="AppOnlyCheckBox"
                                  Grid.Column="2"
                                  Content="App registrations only"
                                  VerticalAlignment="Center"
                                  Foreground="#6B7280"
                                  Checked="FilterOptionsChanged"
                                  Unchecked="FilterOptionsChanged"/>
                    </Grid>
                </Grid>

                <!-- Empty state -->
                <Border Grid.Row="2" x:Name="EmptyState"
                        Background="#FFFFFF" CornerRadius="10" BorderBrush="#E5E7EB" BorderThickness="1"
                        Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock x:Name="EmptyStateIcon" Text="○" FontSize="36" Foreground="#D1D5DB"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock x:Name="EmptyStateTitle" Text="No URL reservations yet"
                                   FontSize="14" Foreground="#4B5563"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="EmptyStateMessage" Text="Register a URL above to get started"
                                   FontSize="12" Foreground="#6B7280"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- List -->
                <ScrollViewer Grid.Row="2" x:Name="UrlListScroll"
                              VerticalScrollBarVisibility="Visible">
                    <ItemsControl x:Name="UrlList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="CardBorder"
                                        Background="#FFFFFF"
                                        CornerRadius="8"
                                        Margin="0,0,0,6"
                                        Padding="16,12">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F3F4F6"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Status dot (green for app entries, gray for external) -->
                                        <Ellipse Grid.Column="0"
                                                 Width="8" Height="8"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,12,0">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="#16A34A"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsExternal}" Value="True">
                                                            <Setter Property="Fill" Value="#9CA3AF"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>

                                        <!-- URL info -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Url}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="#111827"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                <Border Background="#E5E7EB" CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                                                    <TextBlock>
                                                        <Run Text="user: "/>
                                                        <Run Text="{Binding User}"/>
                                                    </TextBlock>
                                                </Border>
                                                <Border Background="#E5E7EB" CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                                                    <TextBlock FontSize="10" Foreground="#6B7280">
                                                        <Run Text="{Binding RegisteredAt, StringFormat='added: {0:MMM dd, HH:mm}'}"/>
                                                    </TextBlock>
                                                </Border>
                                                <Border Background="#FEF3C7" CornerRadius="4" Padding="6,2" Visibility="Collapsed">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsExternal}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="system" FontSize="10" Foreground="#92400E"/>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Copy button -->
                                        <Button Grid.Column="2"
                                                Content="⎘"
                                                FontSize="14"
                                                Cursor="Hand"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="#6B7280" Padding="8,4"
                                                ToolTip="Copy URL"
                                                Tag="{Binding Url}"
                                                Click="CopyUrl_Click"/>

                                        <!-- Remove button (hidden for external entries) -->
                                        <Button Grid.Column="4"
                                                Content="Remove"
                                                Tag="{Binding Url}"
                                                Click="RemoveButton_Click">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource DangerButton}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsExternal}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ── CONSOLE OUTPUT ── -->
        <Border Grid.Row="3" Background="#FFFFFF" Margin="24,10,24,16" CornerRadius="10"
                BorderBrush="#E5E7EB" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Console header -->
                <Border Grid.Row="0" Background="#F9FAFB" CornerRadius="10,10,0,0" Padding="14,8" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="#22C55E" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="OUTPUT" FontSize="10" FontWeight="Bold"
                                       Foreground="#6B7280" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="Clear"
                                Click="ClearLog_Click"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#6B7280" FontSize="11"
                                Cursor="Hand" Padding="0"/>
                    </Grid>
                </Border>

                <!-- Console text (TextBox so output can be selected and copied) -->
                <ScrollViewer Grid.Row="1" x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto" Padding="14,8">
                    <TextBox x:Name="LogTextBlock"
                        FontFamily="Consolas, Courier New"
                        FontSize="11.5"
                        Foreground="#4F8EF7"
                        Background="Transparent"
                        BorderThickness="0"
                        IsReadOnly="True"
                        IsReadOnlyCaretVisible="False"
                        TextWrapping="NoWrap"
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Disabled"
                        Text="— Ready. Enter a URL and click Register."/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
